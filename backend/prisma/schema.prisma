generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  FOOD_DINING
  TRANSPORTATION
  ENTERTAINMENT
  SHOPPING
  OTHERS
}

enum Source {
  MANUAL
  FREE_TEXT
  RECEIPT
}

model Spending {
  id         String   @id
  title      String
  amount     Decimal  @db.Decimal(12, 2)
  category   Category
  source     Source   @default(MANUAL)
  note       String?
  receiptUrl String?
  rawText    String?
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("spendings")
}
